# SSCStudio publish credentials
# ----------------------------------------------------------------------------
# Copy this file to `.env.publish` (gitignored) and fill in the real values.
# `build_dist.py --upload` will load it automatically.
#
# IMPORTANT: never commit `.env.publish` itself.  Only `.env.publish.example`
# (this file, with placeholder values) belongs in the repository.

# Required: target server in user@host:/path format.
# Path is the web-served root that contains v<version>/ and `latest`.
# If you pass only `user@host` (no path), `/var/www/simple.rhythm` is used.
SSC_UPDATE_UPLOAD_TARGET=deploy@toolmgt.mksoft.io:/var/www/simple.rhythm

# Optional: non-default SSH port.  Leave unset to use 22.
# SSC_UPDATE_UPLOAD_PORT=22

# Optional: explicit private-key file (recommended on Windows where ssh
# may not auto-pick up keys outside %USERPROFILE%\.ssh\).
# SSC_UPDATE_SSH_KEY=C:/Users/Admin0/.ssh/id_ed25519
